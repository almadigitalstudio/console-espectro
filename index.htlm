<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Console Espectro V1.0 - Alma Digital Studio</title>
    <style>
        :root { --primary: #0056b3; --bg: #f4f7f6; }
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background: var(--bg); display: flex; flex-direction: column; align-items: center; margin: 0; padding: 20px; }
        .header { text-align: center; margin-bottom: 20px; color: var(--primary); }
        .controls { background: white; padding: 15px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); display: flex; flex-wrap: wrap; gap: 15px; justify-content: center; margin-bottom: 20px; width: 100%; max-width: 800px; }
        .grid-container { background: white; padding: 20px; border-radius: 15px; box-shadow: 0 10px 25px rgba(0,0,0,0.1); margin-top: 10px; }
        .grid { display: grid; gap: 5px; margin: 0 auto; }
        .cell { width: 45px; height: 45px; border: 2px solid #ddd; border-radius: 8px; cursor: pointer; transition: all 0.2s; display: flex; align-items: center; justify-content: center; font-size: 10px; }
        .cell.fixed { cursor: default; border-color: #333; opacity: 0.9; position: relative; }
        .cell.fixed::after { content: "🔒"; position: absolute; font-size: 8px; top: 2px; right: 2px; }
        .palette { display: flex; gap: 10px; margin-top: 20px; background: white; padding: 15px; border-radius: 30px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); }
        .color-btn { width: 40px; height: 40px; border-radius: 50%; border: 3px solid transparent; cursor: pointer; transition: transform 0.2s; }
        .color-btn.active { border-color: #333; transform: scale(1.1); }
        select, button { padding: 8px 12px; border-radius: 6px; border: 1px solid #ddd; font-size: 14px; cursor: pointer; }
        button { background: var(--primary); color: white; border: none; font-weight: bold; }
        .feedback { margin-top: 15px; font-weight: bold; height: 20px; color: #28a745; }
    </style>
</head>
<body>

<div class="header">
    <h1>🧩 Console Espectro V1.0</h1>
    <p>Lógica e Acolhimento - Alma Digital Studio</p>
</div>

<div class="controls">
    <div>
        <label>Formato: </label>
        <select id="gridMode" onchange="initGame()">
            <option value="linear">Modo Linear (1xN)</option>
            <option value="quadrado">Modo Grade (NxN)</option>
        </select>
    </div>
    <div>
        <label>Tamanho: </label>
        <select id="gridSize" onchange="initGame()">
            <option value="3">3</option>
            <option value="4">4</option>
            <option value="5" selected>5</option>
            <option value="8">8</option>
            <option value="10">10</option>
        </select>
    </div>
    <div>
        <label>Acolhimento (Dicas): </label>
        <select id="difficulty" onchange="initGame()">
            <option value="0.9">Máximo (90%+ preenchido)</option>
            <option value="0.7">Alto (70% preenchido)</option>
            <option value="0.5">Médio (50% preenchido)</option>
            <option value="0.2">Desafio (20% preenchido)</option>
        </select>
    </div>
    <button onclick="initGame()">Novo Desafio</button>
</div>

<div class="grid-container">
    <div id="grid" class="grid"></div>
</div>

<div class="feedback" id="message"></div>

<div class="palette" id="palette"></div>

<script>
    const colors = ['#FF4136', '#2ECC40', '#0074D9', '#FFDC00', '#B10DC9', '#FF851B', '#7FDBFF', '#39CCCC', '#F012BE', '#01FF70'];
    let selectedColor = colors[0];
    let solution = [];

    function initGame() {
        const mode = document.getElementById('gridMode').value;
        const size = parseInt(document.getElementById('gridSize').value);
        const diff = parseFloat(document.getElementById('difficulty').value);
        const gridElement = document.getElementById('grid');
        const message = document.getElementById('message');
        
        message.innerText = "";
        gridElement.innerHTML = "";
        
        const rows = (mode === 'linear') ? 1 : size;
        const cols = size;
        
        gridElement.style.gridTemplateColumns = `repeat(${cols}, 45px)`;
        solution = [];

        // Gerar solução lógica simples (sequencial para TEA)
        for (let r = 0; r < rows; r++) {
            let rowSolution = [];
            for (let c = 0; c < cols; c++) {
                rowSolution.push(colors[(r + c) % colors.length]);
            }
            solution.push(rowSolution);
        }

        // Criar células
        for (let r = 0; r < rows; r++) {
            for (let c = 0; c < cols; c++) {
                const cell = document.createElement('div');
                cell.classList.add('cell');
                
                // Aplicar dicas baseado na dificuldade
                if (Math.random() < diff) {
                    cell.style.backgroundColor = solution[r][c];
                    cell.classList.add('fixed');
                }

                cell.onclick = () => {
                    if (!cell.classList.add('fixed')) {
                        cell.style.backgroundColor = selectedColor;
                        checkWin();
                    }
                };
                gridElement.appendChild(cell);
            }
        }
    }

    function createPalette() {
        const palette = document.getElementById('palette');
        colors.forEach((color, index) => {
            const btn = document.createElement('div');
            btn.classList.add('color-btn');
            btn.style.backgroundColor = color;
            if (index === 0) btn.classList.add('active');
            btn.onclick = () => {
                document.querySelectorAll('.color-btn').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                selectedColor = color;
            };
            palette.appendChild(btn);
        });
    }

    function checkWin() {
        const cells = document.querySelectorAll('.cell');
        let playerColors = [];
        cells.forEach(c => playerColors.push(rgbToHex(c.style.backgroundColor)));
        
        const flatSolution = solution.flat().map(c => c.toUpperCase());
        const isComplete = playerColors.every((c, i) => c === flatSolution[i]);

        if (isComplete) {
            document.getElementById('message').innerText = "✨ Incrível! Desafio Concluído! ✨";
        }
    }

    function rgbToHex(rgb) {
        if (!rgb) return "";
        const vals = rgb.match(/\d+/g);
        return "#" + vals.map(x => parseInt(x).toString(16).padStart(2, '0')).join('').toUpperCase();
    }

    createPalette();
    initGame();
</script>

</body>
</html>
